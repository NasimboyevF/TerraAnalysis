# MongoDB
# Локально:   mongodb://localhost:27017/land-degradation
# Atlas (прод): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/land-degradation
MONGO_URI=mongodb://localhost:27017/land-degradation

# JWT
JWT_SECRET=замени_на_свою_длинную_случайную_строку
JWT_EXPIRES_IN=7d

# Сервер
PORT=5000
NODE_ENV=development

# CORS — адрес фронтенда, которому разрешены запросы
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────
# Telegram Bot
# Получить BOT_TOKEN у @BotFather в Telegram
# ─────────────────────────────────────────
BOT_TOKEN=

# Оставь пустым для локальной разработки (бот пойдёт в режиме polling).
# В проде укажи публичный URL бэкенда + /bot-webhook, например:
# BOT_WEBHOOK_URL=https://your-backend.onrender.com/bot-webhook
BOT_WEBHOOK_URL=
